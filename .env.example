ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Tavily for fallback search (set USE_NATIVE_SEARCH=false to use it)
TAVILY_API_KEY=your_tavily_api_key_here

# Set to false to use Tavily/DuckDuckGo instead of Anthropic native search
# USE_NATIVE_SEARCH=true

# Optional: override default model (must support web_search_20260318)
# CLAUDE_MODEL=claude-sonnet-4-6
